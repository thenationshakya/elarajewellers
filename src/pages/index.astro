---
const INSTAGRAM_URL = "https://www.instagram.com/elara.jewellers.np/";
const WHATSAPP_URL = "https://wa.me/9779713610468";

const siteTitle = "Elara Jewellers | Fine Jewellery in Bangemudha, Kathmandu";
const siteDescription =
  "Elara Jewellers — exquisite handcrafted gold, silver & diamond jewellery in Bangemudha, Kathmandu. Explore our latest collections on Instagram or visit us in store.";
const siteUrl = "https://elarajewellers.com.np";

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "JewelryStore",
  name: "Elara Jewellers",
  url: siteUrl,
  logo: `${siteUrl}/og-image.jpg`,
  image: `${siteUrl}/og-image.jpg`,
  description: siteDescription,
  address: {
    "@type": "PostalAddress",
    streetAddress: "Bangemudha",
    addressLocality: "Kathmandu",
    addressCountry: "NP",
  },
  telephone: ["+9779841531790", "+9779713610468"],
  email: "elara.jewellers.np@gmail.com",
  sameAs: [INSTAGRAM_URL],
  openingHoursSpecification: {
    "@type": "OpeningHoursSpecification",
    dayOfWeek: ["Sunday", "Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
    opens: "10:00",
    closes: "19:00",
  },
  priceRange: "NPR",
  currenciesAccepted: "NPR",
  paymentAccepted: "Cash, Online Transfer",
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{siteTitle}</title>
    <meta name="description" content={siteDescription} />
    <meta name="keywords" content="jewellery Kathmandu, gold jewellery Nepal, silver jewellery Kathmandu, Elara Jewellers, Bangemudha jewellers, diamond jewellery Nepal, custom jewellery Kathmandu" />
    <meta name="author" content="Elara Jewellers" />
    <link rel="canonical" href={siteUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={siteDescription} />
    <meta property="og:image" content={`${siteUrl}/og-image.jpg`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="en_NP" />
    <meta property="og:site_name" content="Elara Jewellers" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={siteTitle} />
    <meta name="twitter:description" content={siteDescription} />
    <meta name="twitter:image" content={`${siteUrl}/og-image.jpg`} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#6B0F1A" />

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Atkinson+Hyperlegible:wght@400;700&family=Cormorant+Garamond:ital,wght@0,300;0,400;1,400&display=swap" rel="stylesheet" />
  </head>

  <body>
    <!-- HEADER -->
    <header>
      <nav class="nav-container">
        <a href="/" class="nav-logo" aria-label="Elara Jewellers home">
          <img src="/elara-logo.svg" alt="" class="nav-logo-img" width="32" height="33" />
          <span class="logo-text">ELARA JEWELLERS</span>
        </a>
        <ul class="nav-links">
          <li><a href="#about">About</a></li>
          <li><a href="#collections">Collections</a></li>
          <li><a href="#contact">Contact</a></li>
          <li>
            <a href={INSTAGRAM_URL} target="_blank" rel="noopener noreferrer" class="nav-cta">
              Shop on Instagram
            </a>
          </li>
        </ul>
        <button class="nav-toggle" aria-label="Toggle menu" aria-expanded="false">
          <span></span><span></span><span></span>
        </button>
      </nav>
    </header>

    <main>
      <!-- HERO -->
      <section class="hero">
        <div class="hero-rings" aria-hidden="true">
          <div class="ring ring-1"></div>
          <div class="ring ring-2"></div>
          <div class="ring ring-3"></div>
        </div>
        <div class="hero-inner">
          <img src="/elara-logo.svg" alt="Elara Jewellers logo" class="hero-logo" width="120" height="122" />
          <div class="hero-badge">Bangemudha, Kathmandu</div>
          <h1>Timeless Jewellery,<br /><em>Crafted with Passion</em></h1>
          <p class="hero-sub">
            Discover our exquisite collection of handcrafted gold, silver and diamond jewellery — each piece a celebration of artistry and elegance.
          </p>
          <div class="hero-actions">
            <a href={INSTAGRAM_URL} target="_blank" rel="noopener noreferrer" class="btn btn-primary">
